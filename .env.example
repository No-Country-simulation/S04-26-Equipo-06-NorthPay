# ========================================================================
# NORTHPAY - CONTRACTOR ONBOARDING PORTAL
# Archivo de ejemplo para variables de entorno (Local & Docker)
# ========================================================================

# --- CONFIGURACIÓN DE POSTGRESQL (Base de Datos) ---
# Usadas por la imagen oficial de Docker 'postgres:18.3-alpine'
DB_NAME=northpay_db
DB_USERNAME=admin
DB_PASSWORD=northpay_secret_2026

# Seguridad y Autenticación
JWT_SECRET=ExampleJWTSecretKey005OhV102kyYjAWas02HE8P9nP+ogmQ0bgoc32bCJRTYeKdLGp0uXUGMl5RMl4UlPoQ==
JWT_EXPIRATION_MS=86400000

# --- CONFIGURACIÓN DEL FRONTEND (Next.js) ---
# Esta URL debe ser accesible desde el navegador del usuario
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# --- CORS & SEGURIDAD DE RED ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_COOKIE_SECURE=false
APP_BASE_URL=http://localhost:3000

# --- SERVICIOS EXTERNOS (Simulación de Firma y Documentos) ---
# Variables preparadas para la carga de documentos e identidad
STORAGE_PATH=./uploads
SIGNATURE_API_KEY=test_key_for_digital_contract
ID_VERIFICATION_TOKEN=demo_token_verify

# --- CONFIGURACIÓN DE EMAIL (Notificaciones automáticas) ---
# Para que el sistema avise cuando un operador aprueba un paso
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=notificaciones.northpay@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx